{
  "name": "autoflow-backend",
  "version": "4.0.0",
  "description": "AutoFlow Pro Suite - Full Social Media Automation Backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "worker": "node workers/campaign.worker.js",
    "start:all": "concurrently \"npm run start\" \"npm run worker\" \"npm run media\"",
    "dev:all": "concurrently \"npm run dev\" \"nodemon workers/campaign.worker.js\" \"nodemon workers/media.worker.js\"",
    "lint": "eslint . --ext .js",
    "test": "jest --forceExit --detectOpenHandles",
    "validate:env": "node -e \"require('./utils/validateEnv').validateEnv()\"",
    "media": "node workers/media.worker.js",
    "test:watch": "jest --watch --forceExit",
    "test:coverage": "jest --coverage --forceExit",
    "test:auth": "jest tests/routes/auth.test.js --forceExit",
    "test:routes": "jest tests/routes/ --forceExit",
    "test:services": "jest tests/services/ --forceExit"
  },
  "dependencies": {
